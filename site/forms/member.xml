<?xml version="1.0" encoding="UTF-8"?>
<form>
	<fieldset name="member" addruleprefix="CWM\Component\Cwmconnect\Site\Rule" label="COM_CWMCONNECT_FORM_LABEL">
		<field name="cwmconnect_name"
			type="text"
			id="cwmconnect-name"
			size="30"
			description="COM_CWMCONNECT_MEMBER_EMAIL_NAME_DESC"
			label="COM_CWMCONNECT_MEMBER_EMAIL_NAME_LABEL"
			filter="string"
			required="true"
		/>
		<field name="cwmconnect_email"
			type="email"
			id="cwmconnect-email"
			size="30"
			description="COM_CWMCONNECT_EMAIL_DESC"
			label="JGLOBAL_EMAIL"
			filter="string"
			validate="CwmconnectEmail"
			required="true"
		/>
		<field name="cwmconnect_subject"
			type="text"
			id="cwmconnect-emailmsg"
			size="60"
			description="COM_CWMCONNECT_MEMBER_MESSAGE_SUBJECT_DESC"
			label="COM_CWMCONNECT_MEMBER_MESSAGE_SUBJECT_LABEL"
			filter="string"
			validate="CwmconnectEmailSubject"
			required="true"
		/>
		<field name="cwmconnect_message"
			type="textarea"
			cols="50"
			rows="10"
			id="cwmconnect-message"
			description="COM_CWMCONNECT_MEMBER_ENTER_MESSAGE_DESC"
			label="COM_CWMCONNECT_MEMBER_ENTER_MESSAGE_LABEL"
			filter="htmlsafe"
			validate="CwmconnectEmailMessage"
			required="true"
		/>
		<field name="cwmconnect_email_copy"
			type="checkbox"
			id="cwmconnect-email-copy"
			description="COM_CWMCONNECT_MEMBER_EMAIL_A_COPY_DESC"
			label="COM_CWMCONNECT_MEMBER_EMAIL_A_COPY_LABEL"
			default="0"
		/>

	</fieldset>
</form>