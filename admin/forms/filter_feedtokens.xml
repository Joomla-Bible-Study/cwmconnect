<?xml version="1.0" encoding="utf-8"?>
<form>
	<fields name="filter">
		<field name="search"
		       type="text"
		       label="COM_CWMCONNECT_FILTER_SEARCH_LABEL"
		       hint="JSEARCH_FILTER"
		       inputmode="search"/>

		<field name="status"
		       type="list"
		       label="COM_CWMCONNECT_FEEDTOKEN_HEADING_STATUS"
		       onchange="this.form.submit();">
			<option value="">JSELECT</option>
			<option value="active">COM_CWMCONNECT_FEEDTOKEN_STATUS_ACTIVE</option>
			<option value="revoked">COM_CWMCONNECT_FEEDTOKEN_STATUS_REVOKED</option>
		</field>
	</fields>

	<fields name="list">
		<field name="fullordering"
		       type="list"
		       label="JGLOBAL_SORT_BY"
		       default="a.created_at DESC"
		       onchange="this.form.submit();">
			<option value="">JGLOBAL_SORT_BY</option>
			<option value="a.label ASC">COM_CWMCONNECT_FEEDTOKEN_SORT_LABEL_ASC</option>
			<option value="a.label DESC">COM_CWMCONNECT_FEEDTOKEN_SORT_LABEL_DESC</option>
			<option value="a.created_at ASC">COM_CWMCONNECT_FEEDTOKEN_SORT_CREATED_ASC</option>
			<option value="a.created_at DESC">COM_CWMCONNECT_FEEDTOKEN_SORT_CREATED_DESC</option>
			<option value="a.id ASC">JGRID_HEADING_ID_ASC</option>
			<option value="a.id DESC">JGRID_HEADING_ID_DESC</option>
		</field>

		<field name="limit"
		       type="limitbox"
		       label="JGLOBAL_LIST_LIMIT"
		       default="25"
		       onchange="this.form.submit();"/>
	</fields>
</form>
