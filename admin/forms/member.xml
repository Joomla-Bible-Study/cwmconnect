<?xml version="1.0" encoding="utf-8"?>
<form>
	<fieldset addfieldpath="/administrator/components/com_categories/models/fields">
		<field name="id"
		       type="text"
		       label="JGLOBAL_FIELD_ID_LABEL"
		       description="JGLOBAL_FIELD_ID_DESC"
		       size="10"
		       default="0"
		       readonly="true"
		       class="readonly"
		/>

		<field name="asset_id" type="hidden" filter="unset"/>

		<field name="name" type="text" label="COM_CWMCONNECT_FIELD_NAME_LABEL"
		       description="COM_CWMCONNECT_FIELD_NAME_DESC"
		       class="input-xxlarge input-large-text"
		       size="40"
		       required="true"/>

		<field name="surname" type="text" label="COM_CWMCONNECT_FIELD_SURNAME_LABEL"
		       description="COM_CWMCONNECT_FIELD_SURNAME_DESC" class="inputbox"
		       size="30"/>

		<field name="lname" type="text" label="COM_CWMCONNECT_FIELD_LNAME_LABEL"
		       description="COM_CWMCONNECT_FIELD_LNAME_DESC" class="inputbox"
		       size="30" required="true"/>

		<field name="alias" type="text" label="JFIELD_ALIAS_LABEL"
		       description="JFIELD_ALIAS_DESC" class="inputbox" size="45"/>

		<field name="user_id" type="user"
		       label="COM_CWMCONNECT_FIELD_LINKED_USER_LABEL"
		       description="COM_CWMCONNECT_FIELD_LINKED_USER_DESC"/>

		<field id="published" name="published" type="list" label="JSTATUS"
		       description="JFIELD_PUBLISHED_DESC"
		       class="chzn-color-state"
		       size="1"
		       default="1">
			<option value="1">JPUBLISHED</option>
			<option value="0">JUNPUBLISHED</option>
			<option value="2">JARCHIVED</option>
			<option value="-2">JTRASHED</option>
		</field>

		<field name="catid" type="categoryedit" extension="com_cwmconnect"
		       label="JCATEGORY" description="JFIELD_CATEGORY_DESC"
		       required="true" default=""/>

		<field name="buttonspacer" description="JGLOBAL_ACTION_PERMISSIONS_DESCRIPTION"
		       type="spacer"/>

		<field name="access" type="accesslevel" label="JFIELD_ACCESS_LABEL"
		       description="JFIELD_ACCESS_DESC" size="1"/>

		<field name="sortname1" type="text"
		       label="COM_CWMCONNECT_FIELD_SORTNAME1_LABEL" description="COM_CWMCONNECT_FIELD_SORTNAME1_DESC"
		       class="inputbox" size="30"/>

		<field name="sortname2" type="text"
		       label="COM_CWMCONNECT_FIELD_SORTNAME2_LABEL" description="COM_CWMCONNECT_FIELD_SORTNAME2_DESC"
		       class="inputbox" size="30"/>

		<field name="sortname3" type="text"
		       label="COM_CWMCONNECT_FIELD_SORTNAME3_LABEL" description="COM_CWMCONNECT_FIELD_SORTNAME3_DESC"
		       class="inputbox" size="30"/>

		<field name="con_position" size="15" type="sql" label="COM_CWMCONNECT_FIELD_INFORMATION_POSITION_LABEL"
		       description="COM_CWMCONNECT_FIELD_INFORMATION_POSITION_DESC"
		       query="SELECT id, name FROM #__cwmconnect_position WHERE published = 1 ORDER BY name ASC"
		       key_field="id" value_field="name" multiple="true" default="-1">
			<option value="-1">COM_CWMCONNECT_SELECT_POSITION</option>
		</field>

		<field name="funitid"
		       type="sql"
		       class="inputbox"
		       query="SELECT id, name FROM #__cwmconnect_familyunit WHERE published = 1 ORDER BY name ASC"
		       key_field="id"
		       value_field="name"
		       default="-1"
		       label="COM_CWMCONNECT_FIELD_INFORMATION_FAMILYUNIT_LABEL"
		       description="COM_CWMCONNECT_FIELD_INFORMATION_FAMILYUNIT_DESC"
		>
			<option value="-1">COM_CWMCONNECT_SELECT_FAMILYUNIT</option>
		</field>

		<field name="email_to" type="email"
		       label="JGLOBAL_EMAIL"
		       description="COM_CWMCONNECT_FIELD_INFORMATION_EMAIL_DESC"
		       class="inputbox"
		       cols="30"
		/>

		<field name="address" type="textarea"
		       label="COM_CWMCONNECT_FIELD_INFORMATION_ADDRESS_LABEL"
		       description="COM_CWMCONNECT_FIELD_INFORMATION_ADDRESS_DESC"
		       class="inputbox" rows="3" cols="30"/>

		<field name="suburb" type="text"
		       label="COM_CWMCONNECT_FIELD_INFORMATION_SUBURB_LABEL"
		       description="COM_CWMCONNECT_FIELD_INFORMATION_SUBURB_DESC"
		       class="inputbox" size="30"/>

		<field name="state" type="text"
		       label="COM_CWMCONNECT_FIELD_INFORMATION_STATE_LABEL"
		       description="COM_CWMCONNECT_FIELD_INFORMATION_STATE_DESC" class="inputbox"
		       size="30"/>

		<field name="postcode" type="text"
		       label="COM_CWMCONNECT_FIELD_INFORMATION_POSTCODE_LABEL"
		       description="COM_CWMCONNECT_FIELD_INFORMATION_POSTCODE_DESC"
		       class="inputbox" size="30"/>
		<field name="postcodeaddon" type="text" label=" " default=""
		       class="inputbox" size="10"/>

		<field name="country" type="text"
		       label="COM_CWMCONNECT_FIELD_INFORMATION_COUNTRY_LABEL"
		       description="COM_CWMCONNECT_FIELD_INFORMATION_COUNTRY_DESC"
		       class="inputbox" size="30"/>

		<field name="telephone" type="text"
		       label="COM_CWMCONNECT_FIELD_INFORMATION_TELEPHONE_LABEL"
		       description="COM_CWMCONNECT_FIELD_INFORMATION_TELEPHONE_DESC"
		       class="inputbox" size="30"/>

		<field name="mobile" type="text"
		       label="COM_CWMCONNECT_FIELD_INFORMATION_MOBILE_LABEL"
		       description="COM_CWMCONNECT_FIELD_INFORMATION_MOBILE_DESC"
		       class="inputbox" size="30"/>

		<field name="fax" type="text"
		       label="COM_CWMCONNECT_FIELD_INFORMATION_FAX_LABEL"
		       description="COM_CWMCONNECT_FIELD_INFORMATION_FAX_DESC"
		       class="inputbox" size="30"/>

		<field name="webpage" type="url"
		       label="COM_CWMCONNECT_FIELD_INFORMATION_WEBPAGE_LABEL"
		       description="COM_CWMCONNECT_FIELD_INFORMATION_WEBPAGE_DESC"
		       class="inputbox" size="30"/>

		<field name="misc" type="editor"
		       label="COM_CWMCONNECT_FIELD_INFORMATION_MISC_LABEL"
		       description="COM_CWMCONNECT_FIELD_INFORMATION_MISC_DESC"
		       filter="JComponentHelper::filterText"
		       buttons="true"
		       hide="readmore,pagebreak"
		/>
		<field name="note" type="textarea"
		       label="COM_CWMCONNECT_FIELD_INFORMATION_NOTE_LABEL"
		       description="COM_CWMCONNECT_FIELD_INFORMATION_NOTE_DESC"
		       class="inputbox"
		/>

		<field name="image" type="media" hide_none="1"
		       label="COM_CWMCONNECT_FIELD_PARAMS_IMAGE_LABEL"
		       description="COM_CWMCONNECT_FIELD_PARAMS_IMAGE_DESC"/>

		<field name="created_by" type="user" label="JGLOBAL_FIELD_CREATED_BY_LABEL"
		       description="COM_CWMCONNECT_FIELD_CREATED_BY_DESC"/>

		<field name="created_by_alias" type="text"
		       label="COM_CWMCONNECT_FIELD_CREATED_BY_ALIAS_LABEL"
		       description="COM_CWMCONNECT_FIELD_CREATED_BY_ALIAS_DESC"
		       class="inputbox" size="20"/>

		<field name="created" type="calendar"
		       label="COM_CWMCONNECT_FIELD_CREATED_LABEL" description="COM_CWMCONNECT_FIELD_CREATED_DESC"
		       size="22" format="%Y-%m-%d %H:%M:%S" filter="user_utc"/>

		<field name="modified" type="calendar" class="readonly"
		       label="JGLOBAL_FIELD_MODIFIED_LABEL" description="COM_CWMCONNECT_FIELD_MODIFIED_DESC"
		       size="22" readonly="true" format="%Y-%m-%d %H:%M:%S" filter="user_utc"/>

		<field name="modified_by" type="user" label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
		       class="readonly" readonly="true" filter="unset"/>

		<field name="checked_out" type="hidden" filter="unset"/>

		<field name="checked_out_time" type="hidden" filter="unset"/>

		<field name="ordering" type="ordering" class="inputbox"
		       label="JFIELD_ORDERING_LABEL" description="JFIELD_ORDERING_DESC"
		       content_type="com_cwmconnect.member"/>

		<field name="publish_up" type="calendar"
		       label="COM_CWMCONNECT_FIELD_PUBLISH_UP_LABEL"
		       description="COM_CWMCONNECT_FIELD_PUBLISH_UP_DESC"
		       format="%Y-%m-%d %H:%M:%S" size="22" filter="user_utc"/>

		<field name="publish_down" type="calendar"
		       label="COM_CWMCONNECT_FIELD_PUBLISH_DOWN_LABEL"
		       description="COM_CWMCONNECT_FIELD_PUBLISH_DOWN_DESC"
		       format="%Y-%m-%d %H:%M:%S" size="22" filter="user_utc"/>

		<field name="metakey" type="textarea" label="JFIELD_META_KEYWORDS_LABEL"
		       description="JFIELD_META_KEYWORDS_DESC" class="inputbox" rows="3"
		       cols="30"/>

		<field name="metadesc" type="textarea" label="JFIELD_META_DESCRIPTION_LABEL"
		       description="JFIELD_META_DESCRIPTION_DESC" class="inputbox" rows="3"
		       cols="30"/>

		<field name="language" type="contentlanguage" label="JFIELD_LANGUAGE_LABEL"
		       description="COM_CWMCONNECT_FIELD_LANGUAGE_DESC">
			<option value="*">JALL</option>
		</field>
		<field name="featured" type="radio" label="JFEATURED"
		       description="COM_CWMCONNECT_FIELD_FEATURED_DESC"
		       default="0"
		       class="btn-group btn-group-yesno">
			<option value="0">JNO</option>
			<option value="1">JYES</option>
		</field>

		<field name="lat" type="text" label="COM_CWMCONNECT_FIELD_KML_LAT_LABEL"
		       description="COM_CWMCONNECT_FIELD_KML_LAT_DESC" class="inputbox small"
		       size="11"/>

		<field name="lng" type="text" label="COM_CWMCONNECT_FIELD_KML_LNG_LABEL"
		       description="COM_CWMCONNECT_FIELD_KML_LNG_DESC" class="inputbox small"
		       size="11"/>
		<field name="spouse" type="spouse"
		       label="COM_CWMCONNECT_FIELD_SPOUSE_LABEL" description="COM_CWMCONNECT_FIELD_SPOUSE_DESC"
		       class="readonly small" size="30" readonly="true"/>
		<field name="children_listed" type="children"
		       label="COM_CWMCONNECT_FIELD_CHILDREN_LABEL" description="COM_CWMCONNECT_FIELD_CHILDREN_DESC"
		       class="readonly small" size="500" readonly="true"/>
		<field name="children" type="textarea"
		       label="COM_CWMCONNECT_FIELD_CHILDREN_LABEL" description="COM_CWMCONNECT_FIELD_CHILDREN_DESC"
		       class="inputbox small" rows="3" cols="30"/>
		<field name="anniversary" type="calendar" filter="user_utc"
		       label="COM_CWMCONNECT_FIELD_MEMBER_ANNIVERSARY_LABEL"
		       description="COM_CWMCONNECT_FIELD_MEMBER_ANNIVERSARY_DESC"
		       format="%Y-%m-%d" size="22"/>
		<field name="birthdate" type="calendar" filter="user_utc"
		       label="COM_CWMCONNECT_FIELD_MEMBER_BIRTHDATE_LABEL"
		       description="COM_CWMCONNECT_FIELD_MEMBER_BIRTHDATE_DESC"
		       format="%Y-%m-%d" size="22"/>
		<field name="gender" type="list"
		       label="COM_CWMCONNECT_FIELD_GENDER_LABEL"
		       description="COM_CWMCONNECT_FIELD_GENDER_DESC">
			<option value="">COM_CWMCONNECT_GENDER_SELECT</option>
			<option value="Male">COM_CWMCONNECT_MALE</option>
			<option value="Female">COM_CWMCONNECT_FEMALE</option>
		</field>
		<field name="mstatus" type="list"
		       label="COM_CWMCONNECT_FIELD_MEMBERSSTATUS_LABEL"
		       description="COM_CWMCONNECT_FIELD_MEMBERSSTATUS_DESC"
		       class="inputbox small"
		       default="0">
			<option value="0">COM_CWMCONNECT_ACTIVE_MEMBER</option>
			<option value="1">COM_CWMCONNECT_INACTIVE</option>
			<option value="2">COM_CWMCONNECT_ACTIVE_ATTENDEE</option>
			<option value="3">COM_CWMCONNECT_NONE_MEMBER</option>
			<option value="4">COM_CWMCONNECT_TRANSFERRED</option>
			<option value="5">COM_CWMCONNECT_OTHER</option>
		</field>
	</fieldset>

	<fields name="params">
		<fieldset name="kml" label="COM_CWMCONNECT_KML_OPTIONS"
		          description="COM_CWMCONNECT_KML_OPTIONS_DISC">
			<field name="visibility" type="list"
			       label="COM_CWMCONNECT_FIELD_KML_VISIBILITY_LABEL"
			       description="COM_CWMCONNECT_FIELD_KML_VISIBILITY_MEMBER_DESC"
			       class="inputbox small"
			       default="1">
				<option value="0">JHIDE</option>
				<option value="1">JSHOW</option>
			</field>
			<field name="scale" type="text"
			       label="COM_CWMCONNECT_FIELD_KML_SCALE_LABEL"
			       description="COM_CWMCONNECT_FIELD_KML_SCALE_DESC"
			       class="inputbox small" size="30" default="1.1"/>
			<field name="open" type="list"
			       label="COM_CWMCONNECT_FIELD_KML_OPEN_LABEL"
			       description="COM_CWMCONNECT_FIELD_KML_OPEN_DESC"
			       class="inputbox small"
			       default="0">
				<option value="0">JHIDE</option>
				<option value="1">JSHOW</option>
			</field>
			<field name="gxballoonvisibility" type="list"
			       label="COM_CWMCONNECT_FIELD_KML_GXBOLLOONVISIBILITY_LABEL"
			       description="COM_CWMCONNECT_FIELD_KML_GXBOLLOONVISIBILITY_DESC"
			       class="inputbox small"
			       default="0">
				<option value="0">JHIDE</option>
				<option value="1">JSHOW</option>
			</field>
		</fieldset>
	</fields>
	<fields name="metadata" label="JGLOBAL_FIELDSET_METADATA_OPTIONS">
		<fieldset name="jmetadata" label="JGLOBAL_FIELDSET_METADATA_OPTIONS">

			<field name="robots" type="list" label="JFIELD_METADATA_ROBOTS_LABEL"
			       description="JFIELD_METADATA_ROBOTS_DESC">
				<option value="">JGLOBAL_USE_GLOBAL</option>
				<option value="index, follow">JGLOBAL_INDEX_FOLLOW</option>
				<option value="noindex, follow">JGLOBAL_NOINDEX_FOLLOW</option>
				<option value="index, nofollow">JGLOBAL_INDEX_NOFOLLOW</option>
				<option value="noindex, nofollow">JGLOBAL_NOINDEX_NOFOLLOW</option>
			</field>

			<field name="rights" type="text" label="JFIELD_METADATA_RIGHTS_LABEL"
			       description="JFIELD_METADATA_RIGHTS_DESC" size="20"/>
		</fieldset>
	</fields>
	<fields name="attribs">
		<field name="bpc_date" type="calendar"
		       label="COM_CWMCONNECT_FIELD_BCP_DATE_LABEL"
		       description="COM_CWMCONNECT_FIELD_BCP_DATE_DESC"
		       format="%Y-%m-%d" size="22" filter="user_utc"/>
		<field name="memberotherinfo" type="textarea"
		       label="COM_CWMCONNECT_FIELD_MEMBER_OTHER_INFO_LABEL"
		       description="COM_CWMCONNECT_FIELD_MEMBER_OTHER_INFO_DESC"
		       class="inputbox small" rows="3" cols="30"/>
		<field name="familypostion" type="list"
		       label="COM_CWMCONNECT_FAMILYPOSTION_LABEL"
		       description="COM_CWMCONNECT_FAMILYPOSTION_DESC"
		       class="inputbox"
		       default="0">
			<option value="0">COM_CWMCONNECT_HEAD_OF_HOUSEHOLD</option>
			<option value="1">COM_CWMCONNECT_SPOUSE</option>
			<option value="2">COM_CWMCONNECT_CHILED</option>
		</field>
	</fields>

	<field name="hits" type="text"
	       label="JGLOBAL_HITS"
	       description="COM_CWMCONNECT_HITS_DESC"
	       class="readonly"
	       size="6"
	       readonly="true"
	       filter="unset"/>

	<field name="version" type="text"
	       label="COM_CWMCONNECT_FIELD_VERSION_LABEL"
	       description="COM_CWMCONNECT_FIELD_VERSION_DESC"
	       class="readonly"
	       size="6"
	       readonly="true"
	       filter="unset"/>
</form>
