			<option value="0">JHIDE</option>
			<option value="1">JSHOW</option>
		</field>
		<field name="dr_show_state"
		       type="radio"
		       class="btn-group"
		       default="1"
		       label="COM_CWMCONNECT_FIELD_PARAMS_STATE-COUNTY_LABEL"
		       description="COM_CWMCONNECT_FIELD_PARAMS_STATE-COUNTY_DESC"
		>
			<option value="0">JHIDE</option>
			<option value="1">JSHOW</option>
