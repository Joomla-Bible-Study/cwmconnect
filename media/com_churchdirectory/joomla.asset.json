{
  "$schema": "https://developer.joomla.org/schemas/json-schema/web_assets.json",
  "name": "com_churchdirectory",
  "version": "2.0.0-dev",
  "description": "CWM Connect — Church Photo Directory front-end assets.",
  "license": "GPL-2.0-or-later",
  "assets": [
    {
      "name": "com_churchdirectory.general",
      "type": "style",
      "uri": "com_churchdirectory/css/general.css",
      "dependencies": []
    },
    {
      "name": "com_churchdirectory.directory",
      "type": "style",
      "uri": "com_churchdirectory/css/churchdirectory.css",
      "dependencies": []
    },
    {
      "name": "com_churchdirectory.model",
      "type": "style",
      "uri": "com_churchdirectory/css/model.css",
      "dependencies": []
    },
    {
      "name": "com_churchdirectory.ios",
      "type": "style",
      "uri": "com_churchdirectory/css/ios.css",
      "dependencies": []
    },
    {
      "name": "com_churchdirectory.scripts",
      "type": "script",
      "uri": "com_churchdirectory/js/churchdirectory.js",
      "dependencies": [
        "core"
      ],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "com_churchdirectory.jscolor",
      "type": "script",
      "uri": "com_churchdirectory/js/jscolor.min.js",
      "dependencies": [],
      "attributes": {
        "defer": true
      }
    }
