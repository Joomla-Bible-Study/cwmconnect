<?xml version="1.0" encoding="UTF-8"?>
<!--
    Member photos are private. Direct web access is blocked on IIS; they are
    served only through the gated com_cwmconnect photo proxy
    (index.php?option=com_cwmconnect&task=photo.serve&id=N), which enforces the
    members-only login wall and per-member visibility. mpdf reads these files
    from the filesystem, so the printed directory is unaffected.
-->
<configuration>
    <system.webServer>
        <authorization>
            <deny users="*" />
        </authorization>
    </system.webServer>
</configuration>
