{
    "name": "cwm/cwmconnect",
    "type": "project",
    "description": "CWM Connect — Church Photo Directory component for Joomla 5/6",
    "keywords": [
        "directory",
        "cwmconnect",
        "church",
        "joomla",
        "cwm"
    ],
    "homepage": "https://github.com/Joomla-Bible-Study/cwmconnect",
    "license": "GPL-2.0-or-later",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "platform": {
            "php": "8.4.0"
        },
        "vendor-dir": "libraries/vendor",
        "github-protocols": [
            "https"
        ],
        "allow-plugins": {}
    },
    "support": {
        "issues": "https://www.christianwebministries.org/issues",
        "forum": "https://www.christianwebministries.org/forum",
        "docs": "https://www.christianwebministries.org/docs"
    },
    "autoload": {
        "psr-4": {
            "CWM\\Component\\Cwmconnect\\Administrator\\": "admin/src/",
            "CWM\\Component\\Cwmconnect\\Site\\": "site/src/",
            "CWM\\Plugin\\User\\Cwmconnect\\": "plugins/user/cwmconnect/src/",
            "CWM\\Plugin\\Content\\Cwmconnect\\": "plugins/content/cwmconnect/src/",
            "CWM\\Plugin\\Privacy\\Cwmconnect\\": "plugins/privacy/cwmconnect/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CWM\\Component\\Cwmconnect\\Tests\\": "tests/unit/"
        }
    },
    "require": {
        "php": "^8.4.0",
        "ext-mbstring": "*",
        "ext-json": "*",
        "ext-simplexml": "*",
        "ext-libxml": "*",
        "ext-fileinfo": "*",
        "ext-gd": "*",
        "ext-zip": "*",
        "google/recaptcha": "^1.3",
        "typo3/phar-stream-wrapper": "^3.1.7"
    },
    "require-dev": {
        "cwm/build-tools": "^1.4",
        "phpunit/phpunit": "^12.5",
        "friendsofphp/php-cs-fixer": "^3.0",
        "roave/security-advisories": "dev-latest"
    },
    "replace": {
        "paragonie/random_compat": "9.99.99",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/Joomla-Bible-Study/cwm-build-tools"
        }
    ],
    "scripts": {
        "build":           "php build/build-package.php",
        "test":            "phpunit",
        "lint":            "php-cs-fixer fix --dry-run --diff",
        "lint:fix":        "php-cs-fixer fix",
        "lint:syntax":     "find admin/src site/src modules plugins -type f -name '*.php' -print0 2>/dev/null | xargs -0 -n 1 -P 8 php -l > /dev/null",
        "check":           ["@lint:syntax", "@lint", "@test"],
        "release":         "cwm-release",
        "bump-version":    "cwm-bump",
        "package":         "cwm-package",
        "ars-publish":     "cwm-ars-publish",
        "ars-list":        "cwm-ars-list",
        "changelog":       "cwm-changelog",
        "sync-configs":    "cwm-sync-configs",
        "sync-languages":  "cwm-sync-languages",

        "setup":           "cwm-setup",
        "link":            "cwm-link",
        "link-check":      "cwm-link-check",
        "clean":           "cwm-clean",
        "verify":          "cwm-verify",
        "joomla-install":  "cwm-joomla-install",
        "joomla-latest":   "cwm-joomla-latest"
    }
}
