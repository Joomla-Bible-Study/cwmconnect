<?xml version="1.0" encoding="utf-8"?>
<extension type="component" method="upgrade">
    <name>com_churchdirectory</name>
    <author>CWM Team</author>
    <authorEmail>info@christianwebministries.org</authorEmail>
    <authorUrl>www.christianwebministries.org</authorUrl>
    <copyright>(C) 2026 CWM Team All rights reserved.</copyright>
    <version>2.0.0-dev</version>
    <creationDate>2026-05-06</creationDate>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <description>COM_CHURCHDIRECTORY_XML_DESCRIPTION</description>
    <namespace path="src">CWM\Component\Churchdirectory</namespace>

    <compatibility>
        <cms>
            <targetplatform name="joomla" version="5[.0-9]" />
            <targetplatform name="joomla" version="6[.0-9]" />
        </cms>
        <php minimum="8.4.0" />
    </compatibility>

    <scriptfile>script.php</scriptfile>

    <changelogurl>https://raw.githubusercontent.com/Joomla-Bible-Study/cwmconnect/master/build/cwmconnect-changelog.xml</changelogurl>

    <languages folder="site/language">
        <language tag="en-GB">en-GB/com_churchdirectory.ini</language>
    </languages>

    <install>
        <sql>
            <file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
        </sql>
    </install>

    <uninstall>
        <sql>
            <file driver="mysql" charset="utf8">sql/uninstall.mysql.utf8.sql</file>
        </sql>
    </uninstall>

    <update>
        <schemas>
            <schemapath type="mysql">sql/updates/mysql</schemapath>
        </schemas>
    </update>

    <media destination="com_churchdirectory" folder="media/com_churchdirectory">
        <folder>css</folder>
        <folder>js</folder>
        <folder>images</folder>
    </media>

    <files folder="site">
        <folder>src</folder>
        <folder>tmpl</folder>
    </files>

    <administration>
        <menu img="class:contact">COM_CHURCHDIRECTORY</menu>
        <submenu>
            <menu link="option=com_churchdirectory&amp;view=cpanel"
                  view="cpanel"
                  alt="Churchdirectory/Cpanel">COM_CHURCHDIRECTORY_CPANEL</menu>
            <menu link="option=com_churchdirectory&amp;view=members"
                  view="members"
                  alt="Churchdirectory/Members">COM_CHURCHDIRECTORY_MEMBERS</menu>
            <menu link="option=com_categories&amp;extension=com_churchdirectory"
                  view="categories"
                  alt="Churchdirectory/Categories">COM_CHURCHDIRECTORY_CATEGORIES</menu>
            <menu link="option=com_churchdirectory&amp;view=familyunits"
                  view="familyunits"
                  alt="Churchdirectory/Family Units">COM_CHURCHDIRECTORY_FAMILYUNIT</menu>
            <menu link="option=com_churchdirectory&amp;view=dirheaders"
                  view="dirheaders"
                  alt="Churchdirectory/Directory Headers">COM_CHURCHDIRECTORY_DIRHEADER</menu>
            <menu link="option=com_churchdirectory&amp;view=positions"
                  view="positions"
                  alt="Churchdirectory/Positions">COM_CHURCHDIRECTORY_POSITIONS</menu>
            <menu link="option=com_churchdirectory&amp;view=kmls"
                  view="kmls"
                  alt="Churchdirectory/KML">COM_CHURCHDIRECTORY_KML</menu>
            <menu link="option=com_churchdirectory&amp;view=geoupdate"
                  view="geoupdate"
                  alt="Churchdirectory/GeoUpdate">COM_CHURCHDIRECTORY_GEOUPDATE</menu>
            <menu link="option=com_churchdirectory&amp;view=reports"
                  view="reports"
                  alt="Churchdirectory/Reports">COM_CHURCHDIRECTORY_REPORTS</menu>
            <menu link="option=com_churchdirectory&amp;view=database"
                  view="database"
                  alt="Churchdirectory/DataBase">COM_CHURCHDIRECTORY_DATABASE</menu>
            <menu link="option=com_churchdirectory&amp;view=info"
                  view="info"
                  alt="Churchdirectory/Info">COM_CHURCHDIRECTORY_INFO</menu>
        </submenu>

        <files folder="admin">
            <filename>access.xml</filename>
            <filename>config.xml</filename>
            <folder>forms</folder>
            <folder>services</folder>
            <folder>sql</folder>
            <folder>src</folder>
            <folder>tmpl</folder>
        </files>

        <languages folder="admin/language">
            <language tag="en-GB">en-GB/com_churchdirectory.ini</language>
            <language tag="en-GB">en-GB/com_churchdirectory.sys.ini</language>
        </languages>
    </administration>

    <!-- Tables tracked by Joomla's update mechanism -->
    <tables>
        <table>#__churchdirectory_details</table>
        <table>#__churchdirectory_dirheader</table>
        <table>#__churchdirectory_familyunit</table>
        <table>#__churchdirectory_kml</table>
        <table>#__churchdirectory_position</table>
        <table type="optional">#__churchdirectory_update</table>
    </tables>
</extension>
